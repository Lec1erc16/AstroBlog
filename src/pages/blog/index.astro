---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const PAGE_TITLE = '\u535a\u5ba2\u6587\u7ae0';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1040px, calc(100% - 2rem));
			}
			section > h1 {
				margin-bottom: 1.5rem;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: 100%;
			}
			ul li * {
				text-decoration: none;
				transition: 0.25s ease;
			}
			ul li img {
				width: 100%;
				margin-bottom: 1rem;
				border-radius: 1.25rem;
				aspect-ratio: 16 / 9;
				object-fit: cover;
			}
			ul li a {
				display: block;
				height: 100%;
				padding: 1.5rem;
				border: 1px solid rgba(var(--gray), 0.18);
				border-radius: 1.75rem;
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.96));
				box-shadow: 0 18px 40px rgba(var(--gray), 0.12);
			}
			.title {
				margin: 0 0 0.75rem;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.summary {
				margin: 0 0 1rem;
				color: rgb(var(--gray-dark));
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			ul li a:hover {
				transform: translateY(-4px);
				border-color: rgba(var(--accent), 0.28);
				box-shadow: 0 22px 48px rgba(var(--gray), 0.18);
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				ul {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>{PAGE_TITLE}</h1>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="summary">{post.data.description}</p>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
